{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "noEmit": false,
    "isolatedModules": false,
    "incremental": false,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["src", "shims", "../src"]
}
